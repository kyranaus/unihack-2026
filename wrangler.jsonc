{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "unihack-2026", // 👈 Change this to your project name
  "main": ".output/server/index.mjs", // 👈 Vinxi's server entry point
  "compatibility_date": "2024-11-01",
  "compatibility_flags": [
    "nodejs_compat" 
  ],
  "assets": {
    "directory": ".output/public", // 👈 Vinxi's static assets folder
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
