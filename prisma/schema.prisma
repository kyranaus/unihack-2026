generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

model user {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  isAnonymous   Boolean?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      session[]
  accounts      account[]
  driveSessions DriveSession[]
}

model session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DriveSession {
  id        String       @id @default(cuid())
  userId    String?
  user      user?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt DateTime     @default(now())
  endedAt   DateTime?
  summary   String?
  score     Int?
  cameras   String[]
  videoKey   String?
  videoHash  String?
  txHash     String?
  events     DriveEvent[]
  createdAt DateTime     @default(now())

  @@index([userId])
}

model DriveEvent {
  id         String       @id @default(cuid())
  sessionId  String
  session    DriveSession @relation(fields: [sessionId], references: [id])
  type       String
  camera     String       @default("front")
  elapsedSec Int
  summary    String
  severity   String
  metadata   Json         @default("{}")
  createdAt  DateTime     @default(now())

  @@index([sessionId])
}
